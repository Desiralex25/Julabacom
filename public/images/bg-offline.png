<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 800 600" fill="none">
  <defs>
    <linearGradient id="bgo" x1="0" y1="0" x2="0" y2="1"><stop offset="0%" stop-color="#E8F5E9"/><stop offset="100%" stop-color="#C8E6C9"/></linearGradient>
  </defs>
  <rect width="800" height="600" fill="url(#bgo)"/>
  <!-- Téléphone hors ligne -->
  <rect x="300" y="100" width="200" height="380" rx="28" fill="white" stroke="#4CAF50" stroke-width="4"/>
  <rect x="312" y="116" width="176" height="340" rx="20" fill="#F5F5F5"/>
  <!-- Icône WiFi barré -->
  <path d="M400 220 Q440 195 480 220" stroke="#BDBDBD" stroke-width="8" stroke-linecap="round" fill="none"/>
  <path d="M400 245 Q425 230 450 245" stroke="#BDBDBD" stroke-width="8" stroke-linecap="round" fill="none"/>
  <circle cx="400" cy="268" r="10" fill="#BDBDBD"/>
  <!-- Croix rouge sur le wifi -->
  <line x1="360" y1="195" x2="440" y2="280" stroke="#F44336" stroke-width="8" stroke-linecap="round"/>
  <line x1="440" y1="195" x2="360" y2="280" stroke="#F44336" stroke-width="8" stroke-linecap="round"/>
  <!-- Message hors ligne -->
  <rect x="325" y="310" width="150" height="40" rx="12" fill="#E8F5E9"/>
  <rect x="335" y="320" width="130" height="8" rx="4" fill="#4CAF50"/>
  <rect x="340" y="335" width="80" height="8" rx="4" fill="#81C784"/>
  <!-- Texte fonctionnel -->
  <text x="400" y="395" text-anchor="middle" font-family="Arial,sans-serif" font-size="12" fill="#2E7D32" font-weight="bold">Disponible hors ligne</text>
  <!-- Flèche vers bas -->
  <path d="M400 410 L400 440 L388 428 M400 440 L412 428" stroke="#4CAF50" stroke-width="5" stroke-linecap="round" stroke-linejoin="round" fill="none"/>
  <!-- Stockage local icône -->
  <rect x="355" y="455" width="90" height="55" rx="10" fill="#4CAF50"/>
  <rect x="363" y="465" width="74" height="35" rx="6" fill="rgba(255,255,255,0.3)"/>
  <!-- Plantes décoratives -->
  <rect x="680" y="300" width="10" height="200" fill="#5D4037"/>
  <path d="M685 300 Q660 270 645 240 Q670 270 685 300Z" fill="#43A047"/>
  <path d="M685 300 Q710 270 725 240 Q700 270 685 300Z" fill="#388E3C"/>
  <rect x="110" y="320" width="8" height="180" fill="#6D4C41"/>
  <path d="M114 320 Q90 295 78 268 Q102 293 114 320Z" fill="#2E8B57"/>
  <path d="M114 320 Q138 295 150 268 Q126 293 114 320Z" fill="#43A047"/>
</svg>
