<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 800 600" fill="none">
  <defs>
    <linearGradient id="sky" x1="0" y1="0" x2="0" y2="1"><stop offset="0%" stop-color="#FFF3E0"/><stop offset="100%" stop-color="#FFE0B2"/></linearGradient>
  </defs>
  <rect width="800" height="600" fill="url(#sky)"/>
  <!-- Sol -->
  <rect x="0" y="420" width="800" height="180" fill="#C8A882"/>
  <!-- Étals de marché -->
  <rect x="30" y="280" width="180" height="150" rx="8" fill="#E8771A"/>
  <rect x="30" y="270" width="180" height="20" rx="4" fill="#CC5500"/>
  <!-- Produits sur l'étal 1 -->
  <circle cx="70" cy="340" r="20" fill="#E53935"/>
  <circle cx="110" cy="335" r="18" fill="#F9A825"/>
  <circle cx="150" cy="340" r="20" fill="#43A047"/>
  <circle cx="185" cy="338" r="15" fill="#E53935"/>
  <!-- Étal 2 -->
  <rect x="250" y="290" width="180" height="140" rx="8" fill="#2072AF"/>
  <rect x="250" y="280" width="180" height="20" rx="4" fill="#1565C0"/>
  <circle cx="290" cy="345" r="18" fill="#9C27B0"/>
  <circle cx="330" cy="340" r="20" fill="#F9A825"/>
  <ellipse cx="370" cy="345" rx="15" ry="25" fill="#558B2F"/>
  <circle cx="410" cy="342" r="17" fill="#FF8F00"/>
  <!-- Étal 3 -->
  <rect x="470" y="285" width="180" height="145" rx="8" fill="#2E8B57"/>
  <rect x="470" y="275" width="180" height="20" rx="4" fill="#1B5E20"/>
  <ellipse cx="510" cy="340" rx="18" ry="22" fill="#8B6914"/>
  <ellipse cx="550" cy="338" rx="15" ry="20" fill="#6D4C41"/>
  <circle cx="590" cy="342" r="18" fill="#F57F17"/>
  <circle cx="625" cy="338" r="15" fill="#FBC02D"/>
  <!-- Étal 4 -->
  <rect x="690" y="295" width="100" height="135" rx="8" fill="#9C27B0"/>
  <rect x="690" y="285" width="100" height="20" rx="4" fill="#6A1B9A"/>
  <!-- Palmiers fond -->
  <rect x="720" y="100" width="12" height="190" fill="#5D4037"/>
  <path d="M726 100 Q695 80 680 60 Q710 78 726 100Z" fill="#2E8B57"/>
  <path d="M726 100 Q757 80 772 60 Q742 78 726 100Z" fill="#43A047"/>
  <path d="M726 100 Q720 72 722 50 Q726 75 726 100Z" fill="#2E8B57"/>
  <rect x="100" y="120" width="10" height="170" fill="#6D4C41"/>
  <path d="M105 120 Q78 100 65 80 Q90 98 105 120Z" fill="#388E3C"/>
  <path d="M105 120 Q132 100 145 80 Q120 98 105 120Z" fill="#2E8B57"/>
  <!-- Soleil -->
  <circle cx="650" cy="80" r="55" fill="#FFC107" opacity="0.8"/>
  <circle cx="650" cy="80" r="42" fill="#FFD54F" opacity="0.9"/>
  <!-- Nuages -->
  <ellipse cx="150" cy="60" rx="70" ry="35" fill="white" opacity="0.7"/>
  <ellipse cx="120" cy="65" rx="50" ry="28" fill="white" opacity="0.7"/>
  <ellipse cx="400" cy="40" rx="80" ry="30" fill="white" opacity="0.6"/>
</svg>
