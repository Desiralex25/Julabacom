  <path d="M175 215 Q200 235 225 215" stroke="white" stroke-width="4" stroke-linecap="round" fill="none"/>
  <!-- Micro -->
  <rect x="188" y="290" width="24" height="35" rx="12" fill="#E8771A"/>
