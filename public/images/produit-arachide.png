<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 400 400" fill="none">
  <rect width="400" height="400" rx="32" fill="#FFF8E1"/>
  <!-- Cosse d'arachide -->
  <ellipse cx="200" cy="220" rx="85" ry="55" fill="#D7A84D"/>
  <ellipse cx="200" cy="218" rx="78" ry="49" fill="#E6BC6A"/>
  <!-- Texture cosse -->
  <path d="M140 210 Q160 190 180 210 Q200 230 220 210 Q240 190 260 210" stroke="rgba(160,100,20,0.4)" stroke-width="3" fill="none"/>
  <path d="M138 225 Q158 205 178 225 Q198 245 218 225 Q238 205 258 225" stroke="rgba(160,100,20,0.3)" stroke-width="2" fill="none"/>
  <!-- Étranglement central -->
  <rect x="192" y="178" width="16" height="84" rx="8" fill="#C8944A"/>
  <!-- Grains dans la cosse (transparence) -->
  <ellipse cx="163" cy="220" rx="28" ry="25" fill="#F5DEB3" opacity="0.6"/>
  <ellipse cx="237" cy="220" rx="28" ry="25" fill="#F5DEB3" opacity="0.6"/>
  <!-- Grains sortis -->
  <ellipse cx="120" cy="160" rx="28" ry="22" fill="#D2691E"/>
  <ellipse cx="120" cy="158" rx="24" ry="18" fill="#DEB887"/>
  <ellipse cx="280" cy="165" rx="26" ry="20" fill="#D2691E"/>
  <ellipse cx="280" cy="163" rx="22" ry="16" fill="#DEB887"/>
  <!-- Lignes grain -->
  <path d="M108 152 Q120 145 132 152" stroke="rgba(180,100,30,0.5)" stroke-width="2" fill="none"/>
  <path d="M268 159 Q280 152 292 159" stroke="rgba(180,100,30,0.5)" stroke-width="2" fill="none"/>
  <text x="200" y="355" text-anchor="middle" font-family="Arial,sans-serif" font-size="26" font-weight="bold" fill="#8B4513">Arachides</text>
</svg>
