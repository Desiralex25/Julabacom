<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 800 600" fill="none">
  <defs>
    <linearGradient id="bmp" x1="0" y1="0" x2="1" y2="1"><stop offset="0%" stop-color="#E3F2FD"/><stop offset="100%" stop-color="#BBDEFB"/></linearGradient>
  </defs>
  <rect width="800" height="600" fill="url(#bmp)"/>
  <!-- Écran smartphone stylisé -->
  <rect x="280" y="60" width="240" height="480" rx="30" fill="white" stroke="#2072AF" stroke-width="4"/>
  <rect x="290" y="75" width="220" height="450" rx="22" fill="#F5F9FF"/>
  <!-- Grille de produits -->
  <rect x="300" y="90" width="95" height="90" rx="12" fill="#FFF3E0"/>
  <circle cx="347" cy="120" r="22" fill="#E53935"/>
  <text x="347" y="168" text-anchor="middle" font-family="Arial,sans-serif" font-size="9" fill="#555">Tomates</text>
  <rect x="405" y="90" width="95" height="90" rx="12" fill="#F1F8E9"/>
  <ellipse cx="452" cy="120" rx="18" ry="24" fill="#558B2F"/>
  <text x="452" y="168" text-anchor="middle" font-family="Arial,sans-serif" font-size="9" fill="#555">Gombo</text>
  <rect x="300" y="192" width="95" height="90" rx="12" fill="#FFFDE7"/>
  <ellipse cx="347" cy="222" rx="20" ry="14" fill="#FBC02D"/>
  <text x="347" y="270" text-anchor="middle" font-family="Arial,sans-serif" font-size="9" fill="#555">Maïs</text>
  <rect x="405" y="192" width="95" height="90" rx="12" fill="#FFF8E1"/>
  <ellipse cx="452" cy="225" rx="16" ry="22" fill="#FF8F00"/>
  <text x="452" y="270" text-anchor="middle" font-family="Arial,sans-serif" font-size="9" fill="#555">Mangue</text>
  <!-- Barre de nav -->
  <rect x="290" y="488" width="220" height="35" rx="0" fill="white"/>
  <circle cx="330" cy="505" r="8" fill="#2072AF" opacity="0.5"/>
  <circle cx="400" cy="505" r="8" fill="#2072AF" opacity="0.8"/>
  <circle cx="470" cy="505" r="8" fill="#2072AF" opacity="0.5"/>
  <!-- Flèches connexion -->
  <path d="M100 200 Q180 200 280 280" stroke="#2072AF" stroke-width="3" stroke-dasharray="8 4" fill="none" opacity="0.5"/>
  <path d="M700 200 Q620 200 520 280" stroke="#2072AF" stroke-width="3" stroke-dasharray="8 4" fill="none" opacity="0.5"/>
  <!-- Icônes utilisateurs -->
  <circle cx="80" cy="190" r="40" fill="#E8771A"/>
  <circle cx="80" cy="175" r="18" fill="#FFCCBC"/>
  <ellipse cx="80" cy="215" rx="25" ry="15" fill="#FFCCBC"/>
  <circle cx="720" cy="190" r="40" fill="#2E8B57"/>
  <circle cx="720" cy="175" r="18" fill="#FFCCBC"/>
  <ellipse cx="720" cy="215" rx="25" ry="15" fill="#FFCCBC"/>
</svg>
