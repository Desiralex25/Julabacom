<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 800 600" fill="none">
  <defs>
    <linearGradient id="bgt" x1="0" y1="0" x2="1" y2="1"><stop offset="0%" stop-color="#FFF8E1"/><stop offset="100%" stop-color="#FFE0B2"/></linearGradient>
  </defs>
  <rect width="800" height="600" fill="url(#bgt)"/>
  <!-- Ondes audio stylisées -->
  <path d="M50 300 Q100 250 150 300 Q200 350 250 300" stroke="#FFB300" stroke-width="4" fill="none" opacity="0.4"/>
