<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 800 600" fill="none">
  <defs>
    <linearGradient id="bgmv" x1="0" y1="0" x2="0" y2="1"><stop offset="0%" stop-color="#1A0A00"/><stop offset="100%" stop-color="#4A1500"/></linearGradient>
  </defs>
  <rect width="800" height="600" fill="url(#bgmv)"/>
  <!-- Marché africain coloré en fond sombre -->
  <rect x="0" y="380" width="800" height="220" fill="#3E1A00" opacity="0.8"/>
  <!-- Étals colorés flous -->
  <ellipse cx="150" cy="400" rx="120" ry="40" fill="#E53935" opacity="0.4"/>
  <ellipse cx="400" cy="390" rx="150" ry="50" fill="#F9A825" opacity="0.3"/>
  <ellipse cx="650" cy="400" rx="120" ry="40" fill="#43A047" opacity="0.4"/>
  <!-- Légumes disposés -->
  <circle cx="120" cy="380" r="25" fill="#E53935" opacity="0.8"/>
  <circle cx="175" cy="375" r="22" fill="#F9A825" opacity="0.8"/>
  <circle cx="230" cy="382" r="20" fill="#43A047" opacity="0.8"/>
  <ellipse cx="370" cy="375" rx="25" ry="18" fill="#FBC02D" opacity="0.8"/>
  <circle cx="430" cy="378" r="22" fill="#9C27B0" opacity="0.8"/>
  <ellipse cx="490" cy="372" rx="15" ry="28" fill="#558B2F" opacity="0.8"/>
  <circle cx="580" cy="378" r="24" fill="#E53935" opacity="0.7"/>
  <circle cx="635" cy="374" r="20" fill="#FF8F00" opacity="0.8"/>
  <circle cx="688" cy="380" r="22" fill="#43A047" opacity="0.7"/>
  <!-- Lumières de marché (bokeh) -->
  <circle cx="200" cy="180" r="60" fill="#FFB300" opacity="0.08"/>
  <circle cx="500" cy="150" r="80" fill="#FF6600" opacity="0.06"/>
  <circle cx="750" cy="200" r="55" fill="#FFD54F" opacity="0.07"/>
  <circle cx="80" cy="250" r="45" fill="#FF6600" opacity="0.06"/>
  <!-- Lampes de marché -->
  <circle cx="200" cy="80" r="15" fill="#FFD54F" opacity="0.9"/>
  <line x1="200" y1="20" x2="200" y2="65" stroke="#9E9E9E" stroke-width="3"/>
  <path d="M180 90 Q200 110 220 90" stroke="#FFD54F" stroke-width="2" fill="none" opacity="0.5"/>
  <circle cx="500" cy="60" r="15" fill="#FFD54F" opacity="0.9"/>
  <line x1="500" y1="20" x2="500" y2="45" stroke="#9E9E9E" stroke-width="3"/>
  <circle cx="700" cy="90" r="12" fill="#FFD54F" opacity="0.8"/>
  <line x1="700" y1="20" x2="700" y2="78" stroke="#9E9E9E" stroke-width="3"/>
</svg>
