<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 400 400" fill="none">
  <rect width="400" height="400" rx="32" fill="#F5F0E8"/>
  <!-- Igname principale -->
  <ellipse cx="200" cy="220" rx="90" ry="120" fill="#5D4037" transform="rotate(-8 200 220)"/>
  <ellipse cx="200" cy="220" rx="82" ry="112" fill="#6D4C41" transform="rotate(-8 200 220)"/>
  <!-- Texture rugueuse -->
  <circle cx="160" cy="190" r="5" fill="rgba(0,0,0,0.2)"/>
  <circle cx="185" cy="170" r="4" fill="rgba(0,0,0,0.15)"/>
  <circle cx="220" cy="185" r="5" fill="rgba(0,0,0,0.2)"/>
  <circle cx="240" cy="210" r="4" fill="rgba(0,0,0,0.15)"/>
  <circle cx="175" cy="240" r="5" fill="rgba(0,0,0,0.2)"/>
  <circle cx="215" cy="250" r="4" fill="rgba(0,0,0,0.15)"/>
  <!-- Chair blanche à la coupe -->
  <ellipse cx="200" cy="320" rx="45" ry="20" fill="#FFF8F0"/>
  <!-- Tige -->
  <line x1="198" y1="98" x2="200" y2="130" stroke="#8B6914" stroke-width="7" stroke-linecap="round"/>
  <text x="200" y="380" text-anchor="middle" font-family="Arial,sans-serif" font-size="28" font-weight="bold" fill="#3E2723">Ignames</text>
</svg>
