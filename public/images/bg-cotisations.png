<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 800 600" fill="none">
  <defs>
    <linearGradient id="bgc" x1="0" y1="0" x2="1" y2="1"><stop offset="0%" stop-color="#EDE7F6"/><stop offset="100%" stop-color="#D1C4E9"/></linearGradient>
  </defs>
  <rect width="800" height="600" fill="url(#bgc)"/>
  <!-- Tirelire stylisée -->
  <ellipse cx="400" cy="300" rx="160" ry="140" fill="#9C27B0" opacity="0.8"/>
  <ellipse cx="400" cy="298" rx="153" ry="133" fill="#AB47BC"/>
  <!-- Fente pour pièces -->
  <rect x="358" y="168" width="84" height="16" rx="8" fill="#6A1B9A"/>
  <!-- Groin -->
  <ellipse cx="555" cy="315" rx="35" ry="30" fill="#AB47BC" stroke="#9C27B0" stroke-width="2"/>
  <ellipse cx="562" cy="308" rx="12" ry="10" fill="#6A1B9A"/>
  <ellipse cx="548" cy="308" rx="12" ry="10" fill="#6A1B9A"/>
  <!-- Queue -->
  <path d="M245 310 Q215 290 205 265 Q225 285 245 310Z" fill="#AB47BC"/>
  <!-- Pattes -->
  <rect x="295" y="410" width="45" height="65" rx="22" fill="#9C27B0"/>
  <rect x="355" y="418" width="40" height="60" rx="20" fill="#9C27B0"/>
  <rect x="408" y="416" width="40" height="62" rx="20" fill="#9C27B0"/>
  <rect x="458" y="410" width="45" height="65" rx="22" fill="#9C27B0"/>
  <!-- Pièces qui tombent -->
  <circle cx="395" cy="100" r="20" fill="#FBC02D" stroke="#F9A825" stroke-width="2"/>
  <text x="395" y="107" text-anchor="middle" font-family="serif" font-size="14" font-weight="bold" fill="white">F</text>
  <circle cx="430" cy="60" r="16" fill="#FBC02D" stroke="#F9A825" stroke-width="2"/>
  <circle cx="360" cy="75" r="18" fill="#FFD54F" stroke="#FBC02D" stroke-width="2"/>
  <!-- Reflet -->
  <ellipse cx="345" cy="250" rx="40" ry="25" fill="rgba(255,255,255,0.2)"/>
  <!-- Symbole FCFA -->
  <text x="400" y="330" text-anchor="middle" font-family="serif" font-size="55" font-weight="bold" fill="rgba(255,255,255,0.25)">F</text>
</svg>
